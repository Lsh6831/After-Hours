MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1923196562}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5975f02cb369d7546a1a0b5e94d8b4ac, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MissionManager
  uiManager: {fileID: 1507441158}
  missionSteps:
  - objectiveId: reach_grab_practice
    title: "02 GRAB TEST: \uD0C0\uAC9F \uD655\uC778"
    description: "\uB178\uB780 \uBC29 \uC624\uB978\uCABD\uC758 \uBAA9\uD45C \uD328\uB4DC\uAE4C\uC9C0
      \uC774\uB3D9\uD558\uC138\uC694. \uC55E\uC758 \uCE90\uB9AD\uD130 \uD0C0\uAC9F\uC5D0
      Grab Pack \uC190\uC744 \uBC1C\uC0AC\uD574 \uBD05\uB2C8\uB2E4."
    completionMessage: "Grab Pack \uD14C\uC2A4\uD2B8 \uC9C0\uC810\uC744 \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_storage
    title: "03 STORAGE: \uBCF4\uAD00\uD568 \uD655\uC778"
    description: "\uC8FC\uD669\uC0C9 \uBCF4\uAD00\uC2E4 \uC67C\uCABD \uCEE8\uD14C\uC774\uB108
      \uC55E\uC758 \uBAA9\uD45C \uD328\uB4DC\uAE4C\uC9C0 \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "\uBCF4\uAD00\uD568 \uD655\uC778 \uC644\uB8CC."
  - objectiveId: reach_anchor_room
    title: "04 ANCHOR: \uCD9C\uAD6C\uAE4C\uC9C0 \uB04C\uB824\uAC00\uAE30"
    description: "\uCD08\uB85D\uC0C9 \uBC29\uC758 \uACE0\uC815 \uAE30\uB465\uC744
      \uC7A1\uACE0 \uBC29 \uC55E\uCABD \uBAA9\uD45C \uD328\uB4DC\uAE4C\uC9C0 \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "\uC575\uCEE4 \uC774\uB3D9 \uAD6C\uAC04\uC744 \uD1B5\uACFC\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_core_lab
    title: "05 CORE: Energy Core \uC704\uCE58 \uD655\uC778"
    description: "\uD30C\uB780 \uBC29 \uC67C\uCABD\uC758 Energy Core \uC606 \uBAA9\uD45C
      \uD328\uB4DC\uAE4C\uC9C0 \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "Energy Core \uC704\uCE58\uB97C \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: charge_core
    title: "Energy Core\uB97C Core Station\uC5D0 \uC62C\uB9AC\uAE30"
    description: "Grab Pack\uC73C\uB85C \uD30C\uB780 Energy Core\uB97C \uB04C\uC5B4
      \uD68C\uC0C9 Core Station \uC704\uC5D0 \uC62C\uB9AC\uC138\uC694."
    completionMessage: "\uCDA9\uC804 \uC644\uB8CC. \uB2E4\uC74C \uBCF4\uC548\uBB38\uC774
      \uC5F4\uB838\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_security
    title: "06 SECURITY: \uACBD\uBCF4 \uCF58\uC194 \uD655\uC778"
    description: "\uC5F4\uB9B0 \uBCF4\uC548\uBB38\uC744 \uC9C0\uB098 \uBD89\uC740
      \uBC29 \uC67C\uCABD \uACBD\uBCF4 \uCF58\uC194 \uC55E \uBAA9\uD45C \uD328\uB4DC\uB85C
      \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "\uACBD\uBCF4 \uCF58\uC194 \uD655\uC778 \uC644\uB8CC."
  - objectiveId: reach_puzzle
    title: "07 PUZZLE: \uCD9C\uAD6C \uD328\uB4DC \uB3C4\uCC29"
    description: "\uBD84\uD64D\uC0C9 \uBC29\uC758 \uC88C\uC6B0 \uC575\uCEE4\uB97C
      \uC774\uC6A9\uD574 \uC55E\uCABD \uCD9C\uAD6C \uBAA9\uD45C \uD328\uB4DC\uAE4C\uC9C0
      \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "\uD37C\uC990 \uBC29 \uCD9C\uAD6C\uC5D0 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_airlock
    title: "08 AIRLOCK: \uCF58\uC194 \uD655\uC778"
    description: "\uCCAD\uB85D\uC0C9 \uBC29 \uC624\uB978\uCABD \uBAA9\uD45C \uD328\uB4DC\uB85C
      \uC774\uB3D9\uD574 Airlock \uCF58\uC194\uC744 \uD655\uC778\uD558\uC138\uC694."
    completionMessage: "Airlock \uCF58\uC194 \uD655\uC778 \uC644\uB8CC."
  - objectiveId: reach_decon
    title: "09 DECON: \uC624\uC5FC \uC81C\uAC70 \uB9C1 \uD1B5\uACFC"
    description: "\uB179\uC0C9 \uBC29 \uC67C\uCABD \uD30C\uC774\uD504 \uB9C1 \uC544\uB798
      \uBAA9\uD45C \uD328\uB4DC\uAE4C\uC9C0 \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "\uC624\uC5FC \uC81C\uAC70 \uB9C1 \uD1B5\uACFC \uC644\uB8CC."
  - objectiveId: reach_escape
    title: "10 ESCAPE: \uCD5C\uC885 \uBB38 \uB3C4\uCC29"
    description: "\uBC1D\uC740 \uB9C8\uC9C0\uB9C9 \uBC29\uC758 \uD070 \uCD9C\uAD6C
      \uBB38 \uC55E \uBAA9\uD45C \uD328\uB4DC\uAE4C\uC9C0 \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "Escape Bay\uC5D0 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4. \uD0C8\uCD9C
      \uC131\uACF5!"
  nextMissionDelay: 1.5
