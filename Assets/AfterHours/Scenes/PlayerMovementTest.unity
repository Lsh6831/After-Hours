--- !u!114 &415564683
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 415564682}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5975f02cb369d7546a1a0b5e94d8b4ac, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MissionManager
  uiManager: {fileID: 387982275}
  missionSteps:
  - objectiveId: reach_grab_practice
    title: "02 GRAB TEST\uB85C \uC774\uB3D9"
    description: "\uC55E\uCABD \uC791\uC740 \uBC29\uC73C\uB85C \uB4E4\uC5B4\uAC00\uC138\uC694.
      \uB178\uB780 \uBC29\uC5D0\uC11C \uC88C\uD074\uB9AD/\uC6B0\uD074\uB9AD\uC73C\uB85C
      Grab Pack \uC190\uC744 \uBC1C\uC0AC\uD574 \uBD05\uB2C8\uB2E4."
    completionMessage: "Grab Pack \uD14C\uC2A4\uD2B8 \uBC29\uC5D0 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_storage
    title: "03 STORAGE \uD1B5\uACFC"
    description: "\uB2E4\uC74C \uC8FC\uD669\uC0C9 \uBCF4\uAD00\uC2E4\uB85C \uC774\uB3D9\uD558\uC138\uC694.
      \uC881\uC740 \uBC29\uACFC \uBB38 \uD504\uB808\uC784\uC744 \uB530\uB77C \uC9C4\uD589\uD569\uB2C8\uB2E4."
    completionMessage: "\uBCF4\uAD00\uC2E4\uC744 \uD1B5\uACFC\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_anchor_room
    title: "04 ANCHOR\uC5D0\uC11C \uB04C\uB824\uAC00\uAE30 \uD14C\uC2A4\uD2B8"
    description: "\uCD08\uB85D\uC0C9 \uBC29\uC758 \uACE0\uC815 \uAE30\uB465\uC744
      2\uCD08 \uC774\uC0C1 \uC7A1\uC544 \uD50C\uB808\uC774\uC5B4\uAC00 \uB04C\uB824\uAC00\uB294\uC9C0
      \uD655\uC778\uD558\uC138\uC694."
    completionMessage: "\uC575\uCEE4 \uBC29\uC5D0 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_core_lab
    title: "05 CORE\uC5D0\uC11C Energy Core \uCC3E\uAE30"
    description: "\uD30C\uB780 \uCF54\uC5B4 \uBC29\uC73C\uB85C \uC774\uB3D9\uD558\uC138\uC694.
      \uD30C\uB780 \uACF5\uC774 Energy Core, \uD68C\uC0C9 \uD310\uC774 Core Station\uC785\uB2C8\uB2E4."
    completionMessage: "\uCF54\uC5B4 \uBC29\uC5D0 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: charge_core
    title: "Energy Core\uB97C Core Station\uC5D0 \uC62C\uB9AC\uAE30"
    description: "Grab Pack\uC73C\uB85C \uD30C\uB780 Energy Core\uB97C \uB04C\uC5B4
      \uD68C\uC0C9 Core Station \uC704\uC5D0 \uC62C\uB9AC\uC138\uC694."
    completionMessage: "\uCDA9\uC804 \uC644\uB8CC. \uB2E4\uC74C \uBCF4\uC548\uBB38\uC774
      \uC5F4\uB838\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_security
    title: "06 SECURITY \uD1B5\uACFC"
    description: "\uC5F4\uB9B0 \uD30C\uB780 \uBCF4\uC548\uBB38\uC744 \uC9C0\uB098
      \uBD89\uC740 \uBC29\uC73C\uB85C \uB4E4\uC5B4\uAC00\uC138\uC694. \uB2E4\uC74C
      \uBC29 \uC785\uAD6C\uC758 \uC575\uCEE4\uB97C \uC7A1\uC73C\uBA74 \uC774\uB3D9\uC774
      \uC26C\uC6CC\uC9D1\uB2C8\uB2E4."
    completionMessage: "\uBCF4\uC548 \uBC29\uC744 \uD1B5\uACFC\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_puzzle
    title: "07 PUZZLE\uC5D0\uC11C \uC575\uCEE4 \uC5F0\uACB0"
    description: "\uBD84\uD64D\uC0C9 \uBC29\uC758 \uC88C\uC6B0 \uC575\uCEE4\uB97C
      \uBC88\uAC08\uC544 \uC7A1\uC544 \uB2E4\uC74C \uBB38 \uBC29\uD5A5\uC73C\uB85C
      \uC774\uB3D9\uD558\uC138\uC694."
    completionMessage: "\uD37C\uC990 \uBC29\uC744 \uD1B5\uACFC\uD588\uC2B5\uB2C8\uB2E4."
  - objectiveId: reach_airlock
    title: "08 AIRLOCK \uBB38 \uD1B5\uACFC"
    description: "\uCCAD\uB85D\uC0C9 \uC5D0\uC5B4\uB77D\uC758 \uC5F4\uB9B0 \uC77C\uBC18\uBB38
      \uC0AC\uC774\uB97C \uC9C0\uB098 \uB2E4\uC74C \uBC29\uC73C\uB85C \uC774\uB3D9\uD558\uC138\uC694."
